                f'Exec={exe}\nIcon={DEFAULT_ICON}\nStartupNotify=false\n'
                'X-GNOME-Autostart-enabled=true\n'
            )
    else:
        try:
            os.remove(TRAY_DESKTOP)
        except FileNotFoundError:
            pass

# ── gsettings helpers ─────────────────────────────────────────────────────────

def _parse_gs_list(raw):
    raw = raw.strip()
    if raw.startswith('@as'):
        raw = raw[3:].strip()
    if raw in ('[]', ''):
        return []
    return [p.strip().strip("'\"") for p in raw.strip('[]').split(',') if p.strip().strip("'\"")]


def _gs_find_slot(ksym):
    try:
        out = subprocess.check_output(
            ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
            text=True, timeout=3, stderr=subprocess.DEVNULL,
        )
        for slot in _parse_gs_list(out):
            path   = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
            schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
            b = subprocess.check_output(
                ['gsettings', 'get', schema, 'binding'], text=True, timeout=3,
            ).strip()
            if ksym in b:
                return slot
    except Exception:
        pass
    return None


def _gs_next_slot():
    try:
        out = subprocess.check_output(
            ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
            text=True, timeout=3, stderr=subprocess.DEVNULL,
        )
        existing = set(_parse_gs_list(out))
        i = 0
        while f'custom{i}' in existing:
            i += 1
        return f'custom{i}'
    except Exception:
        return 'custom0'


def _gs_get_binding(ksym):
    slot = _gs_find_slot(ksym)
    if not slot:
        return None, None
    try:
        path   = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
        schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
        name = subprocess.check_output(
            ['gsettings', 'get', schema, 'name'], text=True, timeout=3,
        ).strip().strip("'")
        cmd = subprocess.check_output(
            ['gsettings', 'get', schema, 'command'], text=True, timeout=3,
        ).strip().strip("'")
        return name, cmd
    except Exception:
        return None, None


def _gs_set_binding(ksym, name, command):
    try:
        slot = _gs_find_slot(ksym)
        if not slot:
            slot = _gs_next_slot()
            out = subprocess.check_output(
                ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
                text=True, timeout=3,
            )
            existing = _parse_gs_list(out)
            existing.append(slot)
            new_list = "['" + "', '".join(existing) + "']"
            subprocess.run(
                ['gsettings', 'set', 'org.cinnamon.desktop.keybindings', 'custom-list', new_list],
                timeout=3, check=False,
            )
        path   = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
        schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
        subprocess.run(['gsettings', 'set', schema, 'name',    name],          timeout=3, check=False)
        subprocess.run(['gsettings', 'set', schema, 'command', command],       timeout=3, check=False)
        subprocess.run(['gsettings', 'set', schema, 'binding', f"['{ksym}']"], timeout=3, check=False)
    except Exception:
        pass


def _gs_clear_binding(ksym):
    try:
        slot = _gs_find_slot(ksym)
        if not slot:
            return
        path   = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
        schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
        subprocess.run(['gsettings', 'set', schema, 'binding', '[]'], timeout=3, check=False)
        out = subprocess.check_output(
            ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
            text=True, timeout=3, stderr=subprocess.DEVNULL,
        )
        remaining = [s for s in _parse_gs_list(out) if s != slot]
        new_list  = "['" + "', '".join(remaining) + "']" if remaining else '[]'
        subprocess.run(
            ['gsettings', 'set', 'org.cinnamon.desktop.keybindings', 'custom-list', new_list],
            timeout=3, check=False,
        )
    except Exception:
        pass


# ── TraySection base class ────────────────────────────────────────────────────

class TraySection:
    """
    Base for every tray menu section.

    Subclasses must implement:
      read_state()          → hashable current state
      update_display(state) → update all widgets for this state
      build_menu_items()    → list of Gtk widgets

    The base handles automatically:
      - Periodic polling (set poll_interval_ms on the subclass)
      - Change detection — update_display only called when state changes
      - Read-failure debouncing — a lone FAILURE_STATE reading (e.g. a sysfs
        read that hiccups under load) is ignored rather than treated as a
        real transition and then a real transition back
      - Notification debouncing — fires after notify_debounce_ms of stable state
      - Spurious-notification suppression — apply_change sets _last_state so
        the next poll doesn't treat a user action as an external change
      - on_menu_open defaults to refresh()

    Optional overrides:
      notify_info(state)   → (title, body, icon) or None to suppress
      build_window_frame() → Gtk.Frame for the control panel, or None
      teardown_window()    → clear window widget refs when panel closes
      setup(tray)          → extra init; call super().setup(tray) first
      on_menu_open()       → called on every menu open
      FAILURE_STATE        → value read_state() returns on a failed read
      FAILURE_DEBOUNCE     → consecutive failures required before accepting
    """

    poll_interval_ms = None
    FAILURE_STATE     = None
    FAILURE_DEBOUNCE  = 2

    def __init__(self):
        self._last_state  = None
        self._tray        = None
        self._fail_streak = 0

    def setup(self, tray):
        self._tray = tray
        if self.poll_interval_ms:
            GLib.timeout_add(self.poll_interval_ms, self._poll_tick)

    def _poll_tick(self):
        self.refresh()
        return True

    def refresh(self):
        state = self.read_state()
        if state == self.FAILURE_STATE and self._last_state != self.FAILURE_STATE:
            self._fail_streak += 1
            if self._fail_streak < self.FAILURE_DEBOUNCE:
                return True
        else:
            self._fail_streak = 0
        if state != self._last_state:
            if self._last_state is not None:
                self._schedule_notify(state)
            self._last_state = state
            self.update_display(state)
        return True

    def apply_change(self, value):
        """Apply a user-initiated change and immediately reflect it in the UI."""
        if self._do_apply(value):
            self._last_state = value
            self.update_display(value)

    def _do_apply(self, value):
        return False

    def on_menu_open(self):
        self.refresh()

    def _schedule_notify(self, state):
        if not (self._tray and self._tray.notifications_enabled and HAS_NOTIFY):
            return
        if not self.notify_info(state):
            return
        self._tray.queue_notify(self)

    def read_state(self):
        raise NotImplementedError

    def update_display(self, state):
        raise NotImplementedError

    def notify_info(self, state):
        return None

    def build_menu_items(self):
        raise NotImplementedError

    def build_window_frame(self):
        return None

    def teardown_window(self):
        pass


# ── BacklightSection ──────────────────────────────────────────────────────────

class BacklightSection(TraySection):
    """
    Keyboard backlight control.

    Two polling tiers:
      500 ms sysfs read  — cheap, no sudo, catches Fn+Space instantly
      30 s ACPI read     — catches the auto↔off transition that both read
                           0 in sysfs and so can't be distinguished cheaply
    """

    FAILURE_STATE = 'error'

    def __init__(self):
        super().__init__()
        self._updating     = False
        self._win_updating = False
        self._last_sysfs   = -1
        self._win_radio    = {}

    def setup(self, tray):
        super().setup(tray)
        self._last_sysfs = read_sysfs_brightness()
        GLib.timeout_add(TIMING['backlight_interval_ms'], self._sysfs_poll)
        GLib.timeout_add_seconds(30, self._slow_poll)

    def _sysfs_poll(self):
        val = read_sysfs_brightness()
        if val != self._last_sysfs:
            self._last_sysfs = val
            GLib.idle_add(self.refresh)
        return True

    def _slow_poll(self):
        self.refresh()
        return True

    def read_state(self):
        return get_backlight()

    def _do_apply(self, state):
        return set_backlight(state)

    def update_display(self, state):
        installed = KBD_CMD is not None
        self._warn_item.set_visible(not installed)
        for item in self._radio.values():
            item.set_visible(installed)
        status = state if installed else 'not installed'
        self._header_item.set_label(f'⌨  Backlight: {status}')
        if state in self._radio:
            self._updating = True
            self._radio[state].set_active(True)
            self._updating = False
        if self._win_radio and state in self._win_radio:
            self._win_updating = True
            self._win_radio[state].set_active(True)
            self._win_updating = False

    def notify_info(self, state):
        if state in ('error', None):
            return None
        labels = {k: v for k, v in BACKLIGHT_STATES}
        return ('Keyboard Backlight', labels.get(state, state), DEFAULT_ICON)

    def build_menu_items(self):
        items = []

        self._header_item = Gtk.MenuItem(label='⌨  Backlight: …')
        self._header_item.set_sensitive(False)
        items.append(self._header_item)

        self._warn_item = Gtk.MenuItem(label='⚠  kbd-backlight not installed — run sudo install.sh')
        self._warn_item.set_sensitive(False)
        self._warn_item.set_no_show_all(True)
        items.append(self._warn_item)

        items.append(Gtk.SeparatorMenuItem())

        self._radio = {}
        group = None
        for key, label in BACKLIGHT_STATES:
            item = Gtk.RadioMenuItem.new_with_label(group, label)
            if group is None:
                group = item.get_group()
            item.connect('toggled', self._on_toggled, key)
            items.append(item)
            self._radio[key] = item

        return items

    def _on_toggled(self, widget, state):
        if not self._updating and widget.get_active():
            self.apply_change(state)

    def build_window_frame(self):
        frame = Gtk.Frame(label='⌨  Keyboard Backlight')
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        box.set_border_width(8)
        frame.add(box)
        self._win_radio = {}
        first = None
        for key, label in BACKLIGHT_STATES:
            btn = Gtk.RadioButton.new_with_label_from_widget(first, label)
            if first is None:
                first = btn
            btn.connect('toggled', self._on_win_toggled, key)
            box.pack_start(btn, False, False, 0)
            self._win_radio[key] = btn
        if self._last_state in self._win_radio:
            self._win_updating = True
            self._win_radio[self._last_state].set_active(True)
            self._win_updating = False
        return frame

    def _on_win_toggled(self, widget, state):
        if not self._win_updating and widget.get_active():
            self.apply_change(state)

    def teardown_window(self):
        self._win_radio = {}


# ── ProfileSection ────────────────────────────────────────────────────────────

class ProfileSection(TraySection):
    """Performance profile control. Also drives the tray indicator icon."""

    def __init__(self):
        super().__init__()
        self.poll_interval_ms = TIMING['performance_interval_ms']
        self._updating        = False
        self._win_updating    = False
        self._icons           = {}
        self._win_radio       = {}

    def setup(self, tray):
        super().setup(tray)
        theme = Gtk.IconTheme.get_default()
        for key, candidates in PROFILE_ICON_CANDIDATES.items():
            for name in candidates:
                if theme.has_icon(name):
                    self._icons[key] = name
                    break
            else:
                self._icons[key] = DEFAULT_ICON

    def read_state(self):
        return read_profile()

    def _do_apply(self, profile):
        return set_profile(profile)

    def update_display(self, profile):
        installed = PROFILE_CMD is not None
        self._warn_item.set_visible(not installed)
        for item in self._radio.values():
            item.set_sensitive(installed)

        if profile is None:
            self._header_item.set_label('  Profile: unavailable')
            return

        label = PROFILE_LABELS.get(profile, profile or 'unknown')
        self._header_item.set_label(f'  Profile: {label}')

        if profile in self._radio:
            self._updating = True
            self._radio[profile].set_active(True)
            self._updating = False

        if self._win_radio and profile in self._win_radio:
            self._win_updating = True
            self._win_radio[profile].set_active(True)
            self._win_updating = False

        icon = self._icons.get(profile, DEFAULT_ICON)
        self._tray.set_tray_icon(icon, f'Profile: {label}')

    def notify_info(self, profile):
        if not profile:
            return None
        label = PROFILE_LABELS.get(profile, profile)
        icon  = self._icons.get(profile, DEFAULT_ICON)
        return ('Performance Profile', label, icon)

    def build_menu_items(self):

#!/usr/bin/env python3
"""
kbd-backlight-tray  v1.5
System tray icon for Lenovo Yoga 9i Gen 7 keyboard backlight control.

Right-click the tray icon to see current state and switch modes.
Double-click (v2: opens settings window — not yet implemented).

Usage:
  kbd-backlight-tray [--icon NAME_OR_PATH]

  --icon  Use a fixed icon name (theme) or file path instead of the
          default state-based icons. Example: --icon input-keyboard

Requires: python3-gi, sudo passwordless access to kbd-backlight
Optional: gir1.2-appindicator3-0.1 (better tray integration on Cinnamon)
          gir1.2-notify-0.7       (Fn+Space state-change notifications)
"""

import argparse
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib

import subprocess
import shutil
import sys
import os

# ── CLI args ──────────────────────────────────────────────────────────────────

def _parse_args():
    p = argparse.ArgumentParser(
        description='Keyboard backlight system tray for Lenovo Yoga 9i',
        add_help=True,
    )
    p.add_argument(
        '--icon', metavar='NAME_OR_PATH', default=None,
        help='fixed icon name or file path; disables state-based icon switching',
    )
    return p.parse_args()

ARGS = _parse_args()


# ── autostart helpers ─────────────────────────────────────────────────────────

TRAY_DESKTOP = os.path.expanduser('~/.config/autostart/kbd-backlight-tray.desktop')


def _autostart_exec():
    found = shutil.which('kbd-backlight-tray')
    if found:
        return found
    candidate = os.path.expanduser('~/.local/bin/kbd-backlight-tray')
    if os.path.isfile(candidate):
        return candidate
    return sys.argv[0]


def is_autostart_enabled():
    return os.path.isfile(TRAY_DESKTOP)


def set_autostart(enabled):
    if enabled:
        os.makedirs(os.path.dirname(TRAY_DESKTOP), exist_ok=True)
        with open(TRAY_DESKTOP, 'w') as f:
            f.write(
                '[Desktop Entry]\n'
                'Type=Application\n'
                'Name=Keyboard Backlight Tray\n'
                'Comment=System tray control for Yoga 9i Gen 7 keyboard backlight\n'
                f'Exec={_autostart_exec()}\n'
                'Icon=input-keyboard\n'
                'StartupNotify=false\n'
                'X-GNOME-Autostart-enabled=true\n'
            )
    else:
        try:
            os.remove(TRAY_DESKTOP)
        except FileNotFoundError:
            pass


# ── constants ─────────────────────────────────────────────────────────────────

STATES = [
    ('auto', 'Auto  (ambient light sensor)'),
    ('on',   'On'),
    ('dim',  'Dim'),
    ('off',  'Off'),
]

DEFAULT_ICON = 'input-keyboard'

# How long state must be stable before a notification fires.
# Prevents spam when rapidly cycling through states with Fn+Space.
NOTIFICATION_DEBOUNCE_MS = 1500

# ── persistent preferences ────────────────────────────────────────────────────

CONFIG_DIR = os.path.expanduser('~/.config/kbd-backlight-tray')


def load_pref(name, default):
    try:
        with open(os.path.join(CONFIG_DIR, name)) as f:
            return f.read().strip()
    except FileNotFoundError:
        return default


def save_pref(name, value):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(os.path.join(CONFIG_DIR, name), 'w') as f:
        f.write(str(value))

# Preferred theme icon names per state, in priority order.
# The first name found in the active theme is used; falls back to DEFAULT_ICON.
STATE_ICON_CANDIDATES = {
    'auto': ['keyboard-brightness-symbolic', 'display-brightness-symbolic'],
    'on':   ['keyboard-brightness-high-symbolic', 'display-brightness-high-symbolic'],
    'dim':  ['keyboard-brightness-medium-symbolic', 'display-brightness-medium-symbolic'],
    'off':  ['keyboard-brightness-off-symbolic', 'display-brightness-off-symbolic'],
}

# Sysfs file updated instantly by kernel on Fn+Space — cheap to poll.
SYSFS_BRIGHTNESS = '/sys/class/leds/platform::kbd_backlight/brightness'

# Fast poll watches for sysfs changes (plain file read, no subprocess, no sudo).
SYSFS_POLL_MS = 1000

# Slow background poll catches the one case sysfs misses: auto↔off both
# read 0 in sysfs so no sysfs event fires. ACPI call needed to detect it.
BACKGROUND_POLL_SECONDS = 30


# ── optional libraries ────────────────────────────────────────────────────────

# AppIndicator3: better tray integration on Cinnamon/Ubuntu
try:
    gi.require_version('AppIndicator3', '0.1')
    from gi.repository import AppIndicator3
    HAS_APPINDICATOR = True
except (ValueError, ImportError):
    HAS_APPINDICATOR = False

# Notify: desktop notifications — works across GNOME, Cinnamon, KDE, etc.
# The daemon applies DE-specific settings (DND, sound) automatically.
try:
    gi.require_version('Notify', '0.7')
    from gi.repository import Notify
    HAS_NOTIFY = Notify.init('kbd-backlight-tray')
except Exception:
    HAS_NOTIFY = False


# ── locate kbd-backlight ──────────────────────────────────────────────────────

def find_kbd_cmd():
    found = shutil.which('kbd-backlight')
    if found:
        return found
    for path in ['/usr/local/bin/kbd-backlight', '/usr/bin/kbd-backlight']:
        if os.path.isfile(path):
            return path
    return None

KBD_CMD = find_kbd_cmd()


# ── backend ───────────────────────────────────────────────────────────────────

def _run(args):
    if not KBD_CMD:
        return 'not-installed', False
    try:
        r = subprocess.run(
            ['sudo', KBD_CMD] + args,
            capture_output=True, text=True, timeout=5
        )
        return r.stdout.strip(), r.returncode == 0
    except subprocess.TimeoutExpired:
        return 'timeout', False
    except Exception as e:
        return str(e), False

def get_state():
    out, ok = _run(['get'])
    return out if ok else 'error'

def set_state(state):
    _, ok = _run(['set', state])
    return ok

def read_sysfs_brightness():
    try:
        with open(SYSFS_BRIGHTNESS) as f:
            return int(f.read().strip())
    except (FileNotFoundError, ValueError):
        return -1


# ── tray app ──────────────────────────────────────────────────────────────────

class KbdBacklightTray:
    def __init__(self):
        self._updating = False
        self._last_state = None
        self._last_sysfs = read_sysfs_brightness()
        self._notify_timer = None

        # Resolve which theme icons are actually available, once at startup.
        # --icon overrides everything with a single fixed icon.
        self._state_icons = self._resolve_state_icons()

        self._build_menu()

        if HAS_APPINDICATOR:
            self.indicator = AppIndicator3.Indicator.new(
                'kbd-backlight-tray',
                self._state_icons.get('off', DEFAULT_ICON),
                AppIndicator3.IndicatorCategory.HARDWARE,
            )
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_menu(self.menu)
        else:
            self.status_icon = Gtk.StatusIcon.new_from_icon_name(
                self._state_icons.get('off', DEFAULT_ICON)
            )
            self.status_icon.set_tooltip_text('Keyboard Backlight')
            self.status_icon.connect('popup-menu', self._on_statusicon_popup)
            self.status_icon.connect('activate', self._on_activate)

        self.refresh_state()
        GLib.timeout_add(SYSFS_POLL_MS, self._check_sysfs)
        GLib.timeout_add_seconds(BACKGROUND_POLL_SECONDS, self.refresh_state)

    # ── icon resolution ───────────────────────────────────────────────────────

    def _resolve_state_icons(self):
        """Build a state→icon-name map, probing the active theme once at startup."""
        if ARGS.icon:
            # Fixed icon overrides all state-based switching.
            return {s: ARGS.icon for s in ('auto', 'on', 'dim', 'off', 'error')}

        theme = Gtk.IconTheme.get_default()
        result = {}
        for state, candidates in STATE_ICON_CANDIDATES.items():
            for name in candidates:
                if theme.has_icon(name):
                    result[state] = name
                    break
            else:
                result[state] = DEFAULT_ICON
        result['error'] = DEFAULT_ICON
        return result

    def _set_tray_icon(self, state):
        icon = self._state_icons.get(state, DEFAULT_ICON)
        if HAS_APPINDICATOR:
            self.indicator.set_icon_full(icon, state)
        else:
            self.status_icon.set_from_icon_name(icon)

    # ── menu ──────────────────────────────────────────────────────────────────

    def _build_menu(self):
        self.menu = Gtk.Menu()

        # Refresh state immediately when the menu opens so it's always current.
        self.menu.connect('show', lambda _: GLib.idle_add(self.refresh_state))

        header = Gtk.MenuItem(label='⌨  Keyboard Backlight')
        header.set_sensitive(False)
        self.menu.append(header)

        self.state_item = Gtk.MenuItem(label='Current: …')
        self.state_item.set_sensitive(False)
        self.menu.append(self.state_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        self.warn_item = Gtk.MenuItem(
            label='⚠  kbd-backlight not found — run install.sh'
        )
        self.warn_item.set_sensitive(False)
        self.menu.append(self.warn_item)

        self.radio = {}
        group = None
        for key, label in STATES:
            item = Gtk.RadioMenuItem.new_with_label(group, label)
            if group is None:
                group = item.get_group()
            item.connect('toggled', self._on_toggled, key)
            self.menu.append(item)
            self.radio[key] = item

        self.menu.append(Gtk.SeparatorMenuItem())

        self.notif_item = Gtk.CheckMenuItem(label='Notifications')
        self.notif_item.set_active(load_pref('notifications', 'true') == 'true')
        self.notif_item.connect('toggled', self._on_notif_toggled)
        self.menu.append(self.notif_item)

        self.startup_item = Gtk.CheckMenuItem(label='Run on startup')
        self.startup_item.set_active(is_autostart_enabled())
        self.startup_item.connect('toggled', self._on_startup_toggled)
        self.menu.append(self.startup_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label='Quit')
        quit_item.connect('activate', lambda _: Gtk.main_quit())
        self.menu.append(quit_item)

        self.menu.show_all()

    # ── callbacks ─────────────────────────────────────────────────────────────

    def _on_statusicon_popup(self, icon, button, time):
        self.menu.popup(
            None, None,
            Gtk.StatusIcon.position_menu, icon,
            button, time,
        )

    def _on_activate(self, icon):
        # v2: open settings window on double-click / left-click
        pass

    def _on_toggled(self, widget, state):
        if not self._updating and widget.get_active():
            if set_state(state):
                self._last_state = state  # prevent spurious notification on next poll
                self.state_item.set_label(f'Current: {state}')
                self._set_tray_icon(state)

    def _on_notif_toggled(self, widget):
        save_pref('notifications', 'true' if widget.get_active() else 'false')

    def _on_startup_toggled(self, widget):
        set_autostart(widget.get_active())

    # ── sysfs watcher ─────────────────────────────────────────────────────────

    def _check_sysfs(self):
        """Fast 1s poll of sysfs — no subprocess, no sudo.
        Detects Fn+Space presses instantly for dim/on changes.
        Triggers a full ACPI refresh when a change is seen."""
        val = read_sysfs_brightness()
        if val != self._last_sysfs:
            self._last_sysfs = val
            GLib.idle_add(self.refresh_state)
        return True

    # ── notifications ─────────────────────────────────────────────────────────

    def _notify_state_change(self, state):
        """Schedule a notification, debounced to avoid spam during rapid cycling."""
        if not HAS_NOTIFY or not self.notif_item.get_active():
            return
        if self._notify_timer is not None:
            GLib.source_remove(self._notify_timer)
        self._notify_timer = GLib.timeout_add(
            NOTIFICATION_DEBOUNCE_MS,
            self._fire_notification,
            state,
        )

    def _fire_notification(self, state):
        self._notify_timer = None
        if not self.notif_item.get_active():
            return False
        # Only fire if the state hasn't changed again since we were scheduled.
        if state != self._last_state:
            return False
        labels = {
            'auto': 'Auto  (ambient light sensor)',
            'on':   'On',
            'dim':  'Dim',
            'off':  'Off',
        }
        icon = self._state_icons.get(state, DEFAULT_ICON)
        n = Notify.Notification.new(
            'Keyboard Backlight',
            labels.get(state, state),
            icon,
        )
        n.set_timeout(3000)
        try:
            n.show()
        except Exception:
            pass
        return False  # don't repeat

    # ── state refresh ─────────────────────────────────────────────────────────

    def refresh_state(self):
        installed = KBD_CMD is not None

        self.warn_item.set_visible(not installed)
        for item in self.radio.values():
            item.set_visible(installed)

        if not installed:
            self.state_item.set_label('Current: not installed')
            return True

        state = get_state()

        # Notify on state changes that happened outside the tray (Fn+Space,
        # terminal, resume). Skip notification on the very first read.
        if state != self._last_state:
            if self._last_state is not None:
                self._notify_state_change(state)
            self._last_state = state
            self._set_tray_icon(state)

        self.state_item.set_label(f'Current: {state}')

        if state in self.radio:
            self._updating = True
            self.radio[state].set_active(True)
            self._updating = False

        if HAS_APPINDICATOR:
            self.indicator.set_title(f'Keyboard: {state}')

        return True


# ── entry point ───────────────────────────────────────────────────────────────

def main():
    KbdBacklightTray()
    Gtk.main()

if __name__ == '__main__':
    main()

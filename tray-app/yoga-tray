class RefreshRateSection(TraySection):
    """Refresh rate toggle (90 Hz ↔ 60 Hz)."""

    def __init__(self):
        super().__init__()
        self.poll_interval_ms = TIMING['display_interval_ms']
        self._win_updating    = False
        self._win_radio       = {}

    def read_state(self):
        return get_refresh_rate()

    def update_display(self, rate):
        installed = REFRESH_CMD is not None
        self._warn_item.set_visible(not installed)
        self._toggle_item.set_visible(installed)
        if installed:
            self._toggle_item.set_sensitive(rate is not None)
            if rate is None:
                self._toggle_item.set_label('  Refresh Rate: unavailable')
            else:
                other = 60 if rate == 90 else 90
                self._toggle_item.set_label(f'  Refresh Rate: {rate} Hz → {other} Hz')
        if self._win_radio and rate in self._win_radio:
            self._win_updating = True
            self._win_radio[rate].set_active(True)
            self._win_updating = False

    def build_menu_items(self):
        items = []

        self._warn_item = Gtk.MenuItem(
            label='⚠  refresh-rate-toggle not installed — run install-tray.sh'
        )
        self._warn_item.set_sensitive(False)
        self._warn_item.set_no_show_all(True)
        items.append(self._warn_item)

        self._toggle_item = Gtk.MenuItem(label='  Refresh Rate: … → …')
        self._toggle_item.connect('activate', self._on_toggle)
        items.append(self._toggle_item)

        return items

    def _on_toggle(self, _widget):
        if self._last_state is None:
            return
        toggle_refresh_rate()
        new_rate = 60 if self._last_state == 90 else 90
        self._last_state = new_rate
        self.update_display(new_rate)

    def build_window_frame(self):
        frame = Gtk.Frame(label='  Refresh Rate')
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        box.set_border_width(8)
        frame.add(box)
        self._win_radio = {}
        first = None
        for hz, label in [(90, '90 Hz'), (60, '60 Hz')]:
            btn = Gtk.RadioButton.new_with_label_from_widget(first, label)
            if first is None:
                first = btn
            btn.connect('toggled', self._on_win_toggled, hz)
            box.pack_start(btn, False, False, 0)
            self._win_radio[hz] = btn
        if self._last_state in self._win_radio:
            self._win_updating = True
            self._win_radio[self._last_state].set_active(True)
            self._win_updating = False
        return frame

    def _on_win_toggled(self, widget, hz):
        if not self._win_updating and widget.get_active() and hz != self._last_state:
            toggle_refresh_rate()
            self._last_state = hz
            self.update_display(hz)

    def teardown_window(self):
        self._win_radio = {}


# ── KeyBindingsSection ────────────────────────────────────────────────────────

class KeyBindingsSection(TraySection):
    """
    Bindable special keys.

    Keys with X11 keycodes <= 255 use Cinnamon gsettings custom shortcuts.
    Keys with keycodes > 255 (star, refresh rate) bypass X11 entirely and are
    handled by a background thread reading /dev/input directly. Requires the
    user to be in the 'input' group; a warning is shown if access is denied.
    """

    def __init__(self):
        super().__init__()
        self._key_items  = {}
        self._evdev_ok   = False
        self._win_rows   = {}

    def setup(self, tray):
        super().setup(tray)
        self._evdev_ok = self._start_evdev_thread()
        if hasattr(self, '_evdev_warn_item'):
            self._evdev_warn_item.set_visible(not self._evdev_ok)

    def _start_evdev_thread(self):
        device = _find_ideapad_device()
        if not device:
            return False
        try:
            with open(device, 'rb'):
                pass
        except PermissionError:
            return False
        t = threading.Thread(target=self._evdev_loop, args=(device,), daemon=True)
        t.start()
        return True

    def _evdev_loop(self, device_path):
        try:
            with open(device_path, 'rb') as f:
                while True:
                    data = f.read(_EVDEV_SIZE)
                    if len(data) < _EVDEV_SIZE:
                        break
                    _, _, ev_type, code, value = struct.unpack(_EVDEV_FMT, data)
                    if ev_type == _EV_KEY and value == 1:
                        if code == _KEY_FAVORITES:
                            GLib.idle_add(self._run_key_cmd, 'fav')
                        elif code == _KEY_REFRESH_RATE_TOGGLE:
                            GLib.idle_add(self._run_key_cmd, 'refresh')
        except Exception:
            pass

    def _run_key_cmd(self, key_id):
        cmd = load_pref(f'{key_id}-cmd', '').strip()
        if cmd:
            try:
                subprocess.Popen(shlex.split(cmd))
            except Exception:
                pass
        return False

    # ── TraySection interface ─────────────────────────────────────────────────
    # Key bindings are configuration, not hardware state. We always rebuild
    # the display from config files rather than tracking a "previous state".

    def read_state(self):
        return None

    def refresh(self):
        self.update_display(None)
        return True

    def on_menu_open(self):
        self.update_display(None)

    def update_display(self, _state):
        for row in BINDABLE_KEYS:
            self._update_key_item(*row)
        if self._win_rows:
            self._update_win_rows()

    # ── key item helpers ──────────────────────────────────────────────────────

    def _update_key_item(self, key_id, display_label, ksym, evdev_code):
        item = self._key_items.get(key_id)
        if not item:
            return
        if evdev_code is not None:
            cmd    = load_pref(f'{key_id}-cmd', '').strip()
            name   = load_pref(f'{key_id}-name', '').strip()
            status = name or _cmd_basename(cmd) or 'not bound'
        else:
            name, _ = _gs_get_binding(ksym)
            status   = name if name else 'not bound'
        item.set_label(f'{display_label}  [{status}]')
        item.set_submenu(self._build_key_submenu(key_id, ksym, evdev_code))

    def _build_key_submenu(self, key_id, ksym, evdev_code):
        submenu = Gtk.Menu()

        if evdev_code is not None:
            cmd         = load_pref(f'{key_id}-cmd', '').strip()
            name        = load_pref(f'{key_id}-name', '').strip()
            label       = name or _cmd_basename(cmd)
            header_text = f'Bound: {label}' if label else 'Not bound'
        else:
            name, _     = _gs_get_binding(ksym)
            header_text = f'Bound: {name}' if name else 'Not bound'

        header = Gtk.MenuItem(label=header_text)
        header.set_sensitive(False)
        submenu.append(header)
        submenu.append(Gtk.SeparatorMenuItem())

        for action_label, action_cmd in PRESET_ACTIONS:
            mi = Gtk.MenuItem(label=action_label)
            mi.connect('activate', self._on_bind_preset,
                       key_id, ksym, evdev_code, action_label, action_cmd)
            submenu.append(mi)

        submenu.append(Gtk.SeparatorMenuItem())

        enter_mi = Gtk.MenuItem(label='Enter command…')
        enter_mi.connect('activate', self._on_bind_custom, key_id, ksym, evdev_code)
        submenu.append(enter_mi)

        browse_mi = Gtk.MenuItem(label='Browse for executable…')
        browse_mi.connect('activate', self._on_bind_browse, key_id, ksym, evdev_code)
        submenu.append(browse_mi)

        submenu.append(Gtk.SeparatorMenuItem())

        clear_mi = Gtk.MenuItem(label='Clear binding')
        clear_mi.connect('activate', self._on_clear_binding, key_id, ksym, evdev_code)
        submenu.append(clear_mi)

        submenu.show_all()
        return submenu

    # ── bind callbacks ────────────────────────────────────────────────────────

    def _commit(self, key_id, ksym, evdev_code, name, cmd):
        """Save binding and immediately refresh the tray item and window row."""
        if evdev_code is not None:
            save_pref(f'{key_id}-cmd', cmd)
            save_pref(f'{key_id}-name', name)
        else:
            _gs_set_binding(ksym, name, cmd)
        row = next((r for r in BINDABLE_KEYS if r[0] == key_id), None)
        if row:
            self._update_key_item(*row)
        if self._win_rows:
            self._update_win_rows()

    def _on_bind_preset(self, widget, key_id, ksym, evdev_code, name, cmd):
        self._commit(key_id, ksym, evdev_code, name, cmd)

    def _on_bind_custom(self, widget, key_id, ksym, evdev_code):
        dialog = Gtk.Dialog(title='Key Binding — Enter Command', flags=0)
        dialog.add_buttons(Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
                           Gtk.STOCK_OK,     Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_spacing(8)
        content.set_margin_start(12)
        content.set_margin_end(12)
        content.set_margin_top(12)
        content.set_margin_bottom(4)
        lbl = Gtk.Label(label='Command to run when key is pressed:')
        lbl.set_xalign(0)
        content.add(lbl)
        entry = Gtk.Entry()
        entry.set_width_chars(60)
        entry.set_max_length(500)
        current = (load_pref(f'{key_id}-cmd', '') if evdev_code is not None
                   else (_gs_get_binding(ksym)[1] or ''))
        if current:
            entry.set_text(current)
        entry.connect('activate', lambda _: dialog.response(Gtk.ResponseType.OK))
        content.add(entry)
        dialog.show_all()
        if dialog.run() == Gtk.ResponseType.OK:
            cmd = entry.get_text().strip()
            if cmd:
                name = _cmd_basename(cmd) or cmd if evdev_code is not None else cmd
                self._commit(key_id, ksym, evdev_code, name, cmd)
        dialog.destroy()

    def _on_bind_browse(self, widget, key_id, ksym, evdev_code):
        dialog = Gtk.FileChooserDialog(
            title='Key Binding — Choose Executable',
            parent=None,
            action=Gtk.FileChooserAction.OPEN,
            buttons=(Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
                     Gtk.STOCK_OPEN,   Gtk.ResponseType.OK),
        )
        dialog.set_current_folder(os.path.expanduser('~/.local/bin'))
        if dialog.run() == Gtk.ResponseType.OK:
            path = dialog.get_filename()
            if path:
                self._commit(key_id, ksym, evdev_code, os.path.basename(path), path)
        dialog.destroy()

    def _on_clear_binding(self, widget, key_id, ksym, evdev_code):
        if evdev_code is not None:
            save_pref(f'{key_id}-cmd', '')
            save_pref(f'{key_id}-name', '')
        else:
            _gs_clear_binding(ksym)
        row = next((r for r in BINDABLE_KEYS if r[0] == key_id), None)
        if row:
            self._update_key_item(*row)
        if self._win_rows:
            self._update_win_rows()

    # ── menu building ─────────────────────────────────────────────────────────

    def build_menu_items(self):
        items = []

        header = Gtk.MenuItem(label='  Key Bindings')
        header.set_sensitive(False)
        items.append(header)

        self._evdev_warn_item = Gtk.MenuItem(
            label='⚠  Star/Refresh keys need "input" group — log out and back in'
        )
        self._evdev_warn_item.set_sensitive(False)
        self._evdev_warn_item.set_no_show_all(True)
        items.append(self._evdev_warn_item)

        for key_id, display_label, *_ in BINDABLE_KEYS:
            item = Gtk.MenuItem(label=f'{display_label}  […]')
            items.append(item)
            self._key_items[key_id] = item

        return items

    # ── window frame ──────────────────────────────────────────────────────────

    def build_window_frame(self):
        frame = Gtk.Frame(label='  Key Bindings')
        grid = Gtk.Grid()
        grid.set_border_width(8)
        grid.set_column_spacing(12)
        grid.set_row_spacing(6)
        frame.add(grid)
        self._win_rows = {}
        for i, (key_id, display_label, ksym, evdev_code) in enumerate(BINDABLE_KEYS):
            key_lbl = Gtk.Label(label=display_label)
            key_lbl.set_xalign(0)
            grid.attach(key_lbl, 0, i, 1, 1)
            val_lbl = Gtk.Label(label='…')
            val_lbl.set_xalign(0)
            val_lbl.set_hexpand(True)
            grid.attach(val_lbl, 1, i, 1, 1)
            self._win_rows[key_id] = val_lbl
            mb = Gtk.MenuButton(label='Change…')
            mb.set_popup(self._build_win_key_menu(key_id, ksym, evdev_code))
            grid.attach(mb, 2, i, 1, 1)
        self._update_win_rows()
        return frame

    def _build_win_key_menu(self, key_id, ksym, evdev_code):
        menu = Gtk.Menu()
        for action_label, action_cmd in PRESET_ACTIONS:
            mi = Gtk.MenuItem(label=action_label)
            mi.connect('activate', self._on_bind_preset,
                       key_id, ksym, evdev_code, action_label, action_cmd)
            menu.append(mi)
        menu.append(Gtk.SeparatorMenuItem())
        enter_mi = Gtk.MenuItem(label='Enter command…')
        enter_mi.connect('activate', self._on_bind_custom, key_id, ksym, evdev_code)
        menu.append(enter_mi)
        browse_mi = Gtk.MenuItem(label='Browse for executable…')
        browse_mi.connect('activate', self._on_bind_browse, key_id, ksym, evdev_code)
        menu.append(browse_mi)
        menu.append(Gtk.SeparatorMenuItem())
        clear_mi = Gtk.MenuItem(label='Clear binding')
        clear_mi.connect('activate', self._on_clear_binding, key_id, ksym, evdev_code)
        menu.append(clear_mi)
        menu.show_all()
        return menu

    def _update_win_rows(self):
        for key_id, _, ksym, evdev_code in BINDABLE_KEYS:
            lbl = self._win_rows.get(key_id)
            if not lbl:
                continue
            if evdev_code is not None:
                cmd    = load_pref(f'{key_id}-cmd', '').strip()
                name   = load_pref(f'{key_id}-name', '').strip()
                status = name or _cmd_basename(cmd) or 'not bound'
            else:
                name, _ = _gs_get_binding(ksym)
                status   = name if name else 'not bound'
            lbl.set_label(status)

    def teardown_window(self):
        self._win_rows = {}



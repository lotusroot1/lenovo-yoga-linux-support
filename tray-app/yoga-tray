# ── timing config ─────────────────────────────────────────────────────────────
# Overridable via ~/.config/yoga-tray/timing.conf  (key = value, ms)
#
# notification_delay_ms is relative: effective debounce = max(check intervals) + delay.
# This makes the batching invariant structurally guaranteed — no assertion needed.
# Example: display_interval_ms=30000 + delay=500 → notification fires 30500 ms after first change.
#
_TIMING_DEFAULTS = {
    'notification_delay_ms':   500,   # extra ms after the slowest check before notification fires
    'performance_interval_ms': 500,   # how often to check the current performance profile
    'display_interval_ms':    5000,   # how often to poll display refresh rate
    'backlight_interval_ms':   500,   # how often to check the keyboard backlight brightness
    'conservation_interval_ms': 5000, # how often to check battery conservation mode
}

def _load_timing():
    cfg  = dict(_TIMING_DEFAULTS)
    path = os.path.join(CONFIG_DIR, 'timing.conf')
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith('#'):
                    continue
                if '=' in line:
                    k, _, v = line.partition('=')
                    k = k.strip()
                    if k in cfg:
                        try:
                            val = int(v.strip())
                            if val > 0:
                                cfg[k] = val
                        except ValueError:
                            pass
    except OSError:
        pass
    return cfg

TIMING = _load_timing()


#!/usr/bin/env bash
# Toggle display refresh rate between 90Hz and 60Hz.
#
# On the Yoga 9i Gen 7, 60Hz is only available at native resolution (2880x1800).
# When the current mode is lower (e.g. 1920x1200), switching to 2880x1800 would
# normally cause Cinnamon to change display scaling. We apply an xrandr --scale
# transform so the logical resolution stays the same, and only the refresh rate
# visibly changes.
set -euo pipefail

STATE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/yoga-tray/refresh-rate-state"
OUTPUT=$(xrandr | awk '/ connected/{print $1; exit}')

CURRENT_LINE=$(xrandr | grep -E '^\s+[0-9]+x[0-9]+.*\*' | head -1)
CURRENT_MODE=$(echo "$CURRENT_LINE" | awk '{print $1}')
CURRENT_RATE=$(echo "$CURRENT_LINE" | grep -oP '[\d.]+(?=\*)' | head -1 | cut -d. -f1)

if [ "${CURRENT_RATE:-0}" -ge 85 ]; then
    # Going to 60Hz — switch to native resolution with a scale transform so the
    # logical resolution (and thus display scaling) stays unchanged.
    CURR_W=$(echo "$CURRENT_MODE" | cut -dx -f1)
    CURR_H=$(echo "$CURRENT_MODE" | cut -dx -f2)
    SCALE=$(awk -v cw="$CURR_W" -v ch="$CURR_H" \
        'BEGIN { printf "%.6fx%.6f", 2880/cw, 1800/ch }')

    mkdir -p "$(dirname "$STATE_FILE")"
    echo "${CURRENT_MODE}:90" > "$STATE_FILE"

    xrandr --output "$OUTPUT" --mode 2880x1800 --rate 60 --scale "$SCALE"
    notify-send --urgency=low --expire-time=2000 \
        --icon=video-display-symbolic \
        "Refresh Rate" "60 Hz — Power Saver"
else
    # Restoring to previous mode — reset scale so logical = physical again.
    if [ -f "$STATE_FILE" ]; then
        PREV=$(cat "$STATE_FILE")
        PREV_MODE="${PREV%%:*}"
        PREV_RATE="${PREV##*:}"
    else
        PREV_MODE="2880x1800"
        PREV_RATE="90"
    fi
    xrandr --output "$OUTPUT" --mode "$PREV_MODE" --rate "$PREV_RATE" --scale 1x1
    notify-send --urgency=low --expire-time=2000 \
        --icon=video-display-symbolic \
        "Refresh Rate" "${PREV_RATE} Hz"
fi

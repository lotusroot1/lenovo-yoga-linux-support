# ── backend helpers ───────────────────────────────────────────────────────────

def _find_cmd(name):
    for path in [f'/usr/local/bin/{name}', shutil.which(name)]:
        if path and os.path.isfile(path):
            return path
    return None

KBD_CMD     = _find_cmd('kbd-backlight')
PROFILE_CMD = _find_cmd('platform-profile')
REFRESH_CMD = _find_cmd('refresh-rate-toggle')


def get_refresh_rate():
    try:
        out = subprocess.check_output(['xrandr'], text=True, timeout=3)
        for line in out.splitlines():
            if '*' in line:
                m = re.search(r'(\d+\.\d+)\*', line)
                if m:
                    return 90 if float(m.group(1)) >= 85 else 60
    except Exception:
        pass
    return None


def toggle_refresh_rate():
    if not REFRESH_CMD:
        return False
    try:
        subprocess.Popen([REFRESH_CMD, '--silent'])
        return True
    except Exception:
        return False


# ── gsettings / xmodmap key binding helpers ───────────────────────────────────

def _parse_gs_list(raw):
    raw = raw.strip()
    if raw.startswith('@as'):
        raw = raw[3:].strip()
    if raw in ('[]', ''):
        return []
    return [p.strip().strip("'\"") for p in raw.strip('[]').split(',') if p.strip().strip("'\"")]


def _gs_find_slot(ksym):
    try:
        out = subprocess.check_output(
            ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
            text=True, timeout=3, stderr=subprocess.DEVNULL,
        )
        for slot in _parse_gs_list(out):
            path = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
            schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
            b = subprocess.check_output(
                ['gsettings', 'get', schema, 'binding'], text=True, timeout=3,
            ).strip()
            if ksym in b:
                return slot
    except Exception:
        pass
    return None


def _gs_next_slot():
    try:
        out = subprocess.check_output(
            ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
            text=True, timeout=3, stderr=subprocess.DEVNULL,
        )
        existing = set(_parse_gs_list(out))
        i = 0
        while f'custom{i}' in existing:
            i += 1
        return f'custom{i}'
    except Exception:
        return 'custom0'


def _gs_get_binding(ksym):
    slot = _gs_find_slot(ksym)
    if not slot:
        return None, None
    try:
        path = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
        schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
        name = subprocess.check_output(
            ['gsettings', 'get', schema, 'name'], text=True, timeout=3,
        ).strip().strip("'")
        cmd = subprocess.check_output(
            ['gsettings', 'get', schema, 'command'], text=True, timeout=3,
        ).strip().strip("'")
        return name, cmd
    except Exception:
        return None, None


def _gs_set_binding(ksym, name, command):
    try:
        slot = _gs_find_slot(ksym)
        if not slot:
            slot = _gs_next_slot()
            out = subprocess.check_output(
                ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
                text=True, timeout=3,
            )
            existing = _parse_gs_list(out)
            existing.append(slot)
            new_list = "['" + "', '".join(existing) + "']"
            subprocess.run(
                ['gsettings', 'set', 'org.cinnamon.desktop.keybindings', 'custom-list', new_list],
                timeout=3, check=False,
            )
        path = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
        schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
        subprocess.run(['gsettings', 'set', schema, 'name',    name],          timeout=3, check=False)
        subprocess.run(['gsettings', 'set', schema, 'command', command],       timeout=3, check=False)
        subprocess.run(['gsettings', 'set', schema, 'binding', f"['{ksym}']"], timeout=3, check=False)
    except Exception:
        pass


def _gs_clear_binding(ksym):
    try:
        slot = _gs_find_slot(ksym)
        if not slot:
            return
        path = f'/org/cinnamon/desktop/keybindings/custom-keybindings/{slot}/'
        schema = f'org.cinnamon.desktop.keybindings.custom-keybinding:{path}'
        subprocess.run(['gsettings', 'set', schema, 'binding', '[]'], timeout=3, check=False)
        out = subprocess.check_output(
            ['gsettings', 'get', 'org.cinnamon.desktop.keybindings', 'custom-list'],
            text=True, timeout=3, stderr=subprocess.DEVNULL,
        )
        remaining = [s for s in _parse_gs_list(out) if s != slot]
        new_list = "['" + "', '".join(remaining) + "']" if remaining else '[]'
        subprocess.run(
            ['gsettings', 'set', 'org.cinnamon.desktop.keybindings', 'custom-list', new_list],
            timeout=3, check=False,
        )
    except Exception:
        pass


def _ensure_xmodmap(keycode, keysym_name):
    try:
        subprocess.run(['xmodmap', '-e', f'keycode {keycode} = {keysym_name}'], timeout=3, check=False)
        xmod = os.path.expanduser('~/.Xmodmap')
        entry = f'keycode {keycode} = {keysym_name}'
        try:
            with open(xmod) as f:
                if entry in f.read():
                    return
        except FileNotFoundError:
            pass
        with open(xmod, 'a') as f:
            f.write(entry + '\n')
    except Exception:
        pass


def _sudo_run(cmd, *args):
    try:
        r = subprocess.run(
            ['sudo', cmd] + list(args),
            capture_output=True, text=True, timeout=5,
        )
        return r.stdout.strip(), r.returncode == 0
    except Exception as e:
        return str(e), False


def get_backlight():
    if not KBD_CMD:
        return 'error'
    out, ok = _sudo_run(KBD_CMD, 'get')
    return out if ok else 'error'


def set_backlight(state):
    if not KBD_CMD:
        return False
    _, ok = _sudo_run(KBD_CMD, 'set', state)
    return ok


def read_sysfs_brightness():
    try:
        with open(SYSFS_BRIGHTNESS) as f:
            return int(f.read().strip())
    except (FileNotFoundError, ValueError):
        return -1


def read_profile():
    try:
        with open(SYSFS_PROFILE) as f:
            return f.read().strip()
    except Exception:
        return None


def set_profile(profile):
    if not PROFILE_CMD:
        return False
    _, ok = _sudo_run(PROFILE_CMD, 'set', profile)
    return ok

# ── persistent preferences ────────────────────────────────────────────────────

def load_pref(name, default):
    try:
        with open(os.path.join(CONFIG_DIR, name)) as f:
            return f.read().strip()
    except FileNotFoundError:
        return default


def save_pref(name, value):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(os.path.join(CONFIG_DIR, name), 'w') as f:
        f.write(str(value))

# ── autostart ─────────────────────────────────────────────────────────────────

def is_autostart_enabled():
    return os.path.isfile(TRAY_DESKTOP)


def set_autostart(enabled):
    if enabled:
        os.makedirs(os.path.dirname(TRAY_DESKTOP), exist_ok=True)
        exe = shutil.which('yoga-tray') or sys.argv[0]
        with open(TRAY_DESKTOP, 'w') as f:
            f.write(
                '[Desktop Entry]\n'
                'Type=Application\n'
                'Name=Yoga Tray\n'
                'Comment=Keyboard backlight and performance profile for Yoga 9i Gen 7\n'
                f'Exec={exe}\n'
                f'Icon={DEFAULT_ICON}\n'
                'StartupNotify=false\n'
                'X-GNOME-Autostart-enabled=true\n'
            )
    else:
        try:
            os.remove(TRAY_DESKTOP)
        except FileNotFoundError:
            pass

# ── tray app ──────────────────────────────────────────────────────────────────

class YogaTray:
    def __init__(self):
        self._bl_updating      = False
        self._last_backlight   = None
        self._last_sysfs_br    = read_sysfs_brightness()
        self._bl_notify_timer  = None

        self._pf_updating      = False
        self._last_profile     = None
        self._pf_notify_timer  = None

        self._rr_updating      = False
        self._last_rate        = None

        self.kb_menu_items     = {}

        self._profile_icons = self._resolve_profile_icons()

        self._build_menu()

        if HAS_APPINDICATOR:
            self.indicator = AppIndicator3.Indicator.new(
                'yoga-tray',
                DEFAULT_ICON,
                AppIndicator3.IndicatorCategory.HARDWARE,
            )
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_menu(self.menu)
        else:
            self.status_icon = Gtk.StatusIcon.new_from_icon_name(DEFAULT_ICON)
            self.status_icon.set_tooltip_text('Yoga 9i — Backlight & Profile')
            self.status_icon.connect('popup-menu', self._on_statusicon_popup)

        self.refresh_backlight()
        self.refresh_profile()
        self.refresh_refresh_rate()

        GLib.timeout_add(BACKLIGHT_POLL_MS,          self._check_sysfs_brightness)
        GLib.timeout_add(PROFILE_POLL_MS,            self._poll_profile)
        GLib.timeout_add_seconds(REFRESH_RATE_POLL_S, self._poll_refresh_rate)

    # ── icon ──────────────────────────────────────────────────────────────────

    def _resolve_profile_icons(self):
        theme = Gtk.IconTheme.get_default()
        result = {}
        for key, candidates in PROFILE_ICON_CANDIDATES.items():
            for name in candidates:
                if theme.has_icon(name):
                    result[key] = name
                    break
            else:
                result[key] = DEFAULT_ICON
        return result

    def _set_tray_icon(self, profile):
        icon = self._profile_icons.get(profile, DEFAULT_ICON)
        if HAS_APPINDICATOR:
            label = PROFILE_LABELS.get(profile, profile or '')
            self.indicator.set_icon_full(icon, label)
            self.indicator.set_title(f'Profile: {label}')
        else:
            self.status_icon.set_from_icon_name(icon)

    # ── menu ──────────────────────────────────────────────────────────────────

    def _build_menu(self):
        self.menu = Gtk.Menu()
        self.menu.connect('show', lambda _: GLib.idle_add(self._on_menu_open))

        # ── backlight section ─────────────────────────────────────────────────
        bl_header = Gtk.MenuItem(label='⌨  Keyboard Backlight')
        bl_header.set_sensitive(False)
        self.menu.append(bl_header)

        self.bl_state_item = Gtk.MenuItem(label='Current: …')
        self.bl_state_item.set_sensitive(False)
        self.menu.append(self.bl_state_item)

        self.bl_warn_item = Gtk.MenuItem(label='⚠  kbd-backlight not installed — run sudo install.sh')
        self.bl_warn_item.set_sensitive(False)
        self.bl_warn_item.set_no_show_all(True)
        self.menu.append(self.bl_warn_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        self.bl_radio = {}
        group = None
        for key, label in BACKLIGHT_STATES:
            item = Gtk.RadioMenuItem.new_with_label(group, label)
            if group is None:
                group = item.get_group()
            item.connect('toggled', self._on_bl_toggled, key)
            self.menu.append(item)
            self.bl_radio[key] = item

        self.menu.append(Gtk.SeparatorMenuItem())

        # ── performance profile section ───────────────────────────────────────
        pf_header = Gtk.MenuItem(label='  Performance Profile')
        pf_header.set_sensitive(False)
        self.menu.append(pf_header)

        self.pf_state_item = Gtk.MenuItem(label='Current: …')
        self.pf_state_item.set_sensitive(False)
        self.menu.append(self.pf_state_item)

        self.pf_warn_item = Gtk.MenuItem(label='⚠  platform-profile not installed — run sudo install.sh')
        self.pf_warn_item.set_sensitive(False)
        self.pf_warn_item.set_no_show_all(True)
        self.menu.append(self.pf_warn_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        self.pf_radio = {}
        group = None
        for key, label in PROFILES:
            item = Gtk.RadioMenuItem.new_with_label(group, label)
            if group is None:
                group = item.get_group()
            item.connect('toggled', self._on_pf_toggled, key)
            self.menu.append(item)
            self.pf_radio[key] = item

        self.menu.append(Gtk.SeparatorMenuItem())

        # ── refresh rate section ──────────────────────────────────────────────
        rr_header = Gtk.MenuItem(label='  Refresh Rate')
        rr_header.set_sensitive(False)
        self.menu.append(rr_header)

        self.rr_state_item = Gtk.MenuItem(label='Current: …')
        self.rr_state_item.set_sensitive(False)
        self.menu.append(self.rr_state_item)

        self.rr_warn_item = Gtk.MenuItem(
            label='⚠  refresh-rate-toggle not installed — run install-tray.sh'
        )
        self.rr_warn_item.set_sensitive(False)
        self.rr_warn_item.set_no_show_all(True)
        self.menu.append(self.rr_warn_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        self.rr_radio = {}
        group = None
        for hz, label in [(90, '90 Hz'), (60, '60 Hz — Power Saver')]:
            item = Gtk.RadioMenuItem.new_with_label(group, label)
            if group is None:
                group = item.get_group()
            item.connect('toggled', self._on_rr_toggled, hz)
            self.menu.append(item)
            self.rr_radio[hz] = item

        self.menu.append(Gtk.SeparatorMenuItem())

        # ── key bindings section ──────────────────────────────────────────────
        kb_header = Gtk.MenuItem(label='  Key Bindings')
        kb_header.set_sensitive(False)
        self.menu.append(kb_header)

        for key_id, display_label, *_ in BINDABLE_KEYS:
            item = Gtk.MenuItem(label=f'{display_label}  […]')
            self.menu.append(item)
            self.kb_menu_items[key_id] = item

        self.menu.append(Gtk.SeparatorMenuItem())

        # ── preferences ───────────────────────────────────────────────────────
        self.notif_item = Gtk.CheckMenuItem(label='Notifications')
        self.notif_item.set_active(load_pref('notifications', 'true') == 'true')
        self.notif_item.connect('toggled', lambda w: save_pref(
            'notifications', 'true' if w.get_active() else 'false'
        ))
        self.menu.append(self.notif_item)

        self.startup_item = Gtk.CheckMenuItem(label='Run on startup')
        self.startup_item.set_active(is_autostart_enabled())
        self.startup_item.connect('toggled', lambda w: set_autostart(w.get_active()))
        self.menu.append(self.startup_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label='Quit')
        quit_item.connect('activate', lambda _: Gtk.main_quit())
        self.menu.append(quit_item)

        self.menu.show_all()

    def _on_menu_open(self):
        self.refresh_backlight()
        self.refresh_profile()
        self.refresh_refresh_rate()
        self._rebuild_key_binding_submenus()

    # ── backlight callbacks ───────────────────────────────────────────────────

    def _on_statusicon_popup(self, icon, button, time):
        self.menu.popup(None, None, Gtk.StatusIcon.position_menu, icon, button, time)

    def _on_bl_toggled(self, widget, state):
        if not self._bl_updating and widget.get_active():
            if set_backlight(state):
                self._last_backlight = state
                self.bl_state_item.set_label(f'Current: {state}')

    def _check_sysfs_brightness(self):
        val = read_sysfs_brightness()
        if val != self._last_sysfs_br:
            self._last_sysfs_br = val
            GLib.idle_add(self.refresh_backlight)
        return True

    def refresh_backlight(self):
        installed = KBD_CMD is not None
        self.bl_warn_item.set_visible(not installed)
        for item in self.bl_radio.values():
            item.set_visible(installed)

        if not installed:
            self.bl_state_item.set_label('Current: not installed')
            return True

        state = get_backlight()
        if state != self._last_backlight:
            if self._last_backlight is not None:
                self._schedule_notification('backlight', state)
            self._last_backlight = state

        self.bl_state_item.set_label(f'Current: {state}')
        if state in self.bl_radio:
            self._bl_updating = True
            self.bl_radio[state].set_active(True)
            self._bl_updating = False

        return True

    # ── profile callbacks ─────────────────────────────────────────────────────

    def _on_pf_toggled(self, widget, profile):
        if not self._pf_updating and widget.get_active():
            if set_profile(profile):
                self._last_profile = profile
                self._update_profile_display(profile)

    def _poll_profile(self):
        self.refresh_profile()
        return True

    def refresh_profile(self):
        installed = PROFILE_CMD is not None
        self.pf_warn_item.set_visible(not installed)
        for item in self.pf_radio.values():
            item.set_sensitive(installed)

        profile = read_profile()
        if profile is None:
            self.pf_state_item.set_label('Current: unavailable')
            return True

        if profile != self._last_profile:
            if self._last_profile is not None:
                self._schedule_notification('profile', profile)
            self._last_profile = profile
            self._update_profile_display(profile)

        return True

    def _update_profile_display(self, profile):
        label = PROFILE_LABELS.get(profile, profile or 'unknown')
        self.pf_state_item.set_label(f'Current: {label}')
        self._set_tray_icon(profile)

        if profile in self.pf_radio:
            self._pf_updating = True
            self.pf_radio[profile].set_active(True)
            self._pf_updating = False

    # ── notifications ─────────────────────────────────────────────────────────

    def _schedule_notification(self, kind, value):
        if not HAS_NOTIFY or not self.notif_item.get_active():
            return
        if kind == 'backlight':
            if self._bl_notify_timer is not None:
                GLib.source_remove(self._bl_notify_timer)
            self._bl_notify_timer = GLib.timeout_add(
                BACKLIGHT_DEBOUNCE_MS, self._fire_backlight_notification, value
            )
        else:
            if self._pf_notify_timer is not None:
                GLib.source_remove(self._pf_notify_timer)
            self._pf_notify_timer = GLib.timeout_add(
                PROFILE_DEBOUNCE_MS, self._fire_profile_notification, value
            )

    def _fire_backlight_notification(self, state):
        self._bl_notify_timer = None
        if not self.notif_item.get_active() or state != self._last_backlight:
            return False
        labels = {k: v for k, v in BACKLIGHT_STATES}
        n = Notify.Notification.new('Keyboard Backlight', labels.get(state, state), DEFAULT_ICON)
        n.set_timeout(2000)
        try:
            n.show()
        except Exception:
            pass
        return False

    def _fire_profile_notification(self, profile):
        self._pf_notify_timer = None
        if not self.notif_item.get_active() or profile != self._last_profile:
            return False
        label = PROFILE_LABELS.get(profile, profile)
        icon  = self._profile_icons.get(profile, DEFAULT_ICON)
        n = Notify.Notification.new('Performance Profile', label, icon)
        n.set_timeout(2000)
        try:
            n.show()
        except Exception:
            pass
        return False

    # ── refresh rate ──────────────────────────────────────────────────────────

    def _on_rr_toggled(self, widget, hz):
        if not self._rr_updating and widget.get_active():
            if hz != self._last_rate:
                toggle_refresh_rate()

    def _poll_refresh_rate(self):
        self.refresh_refresh_rate()
        return True

    def refresh_refresh_rate(self):
        installed = REFRESH_CMD is not None
        self.rr_warn_item.set_visible(not installed)
        for item in self.rr_radio.values():
            item.set_sensitive(installed)

        rate = get_refresh_rate()
        if rate is None:
            self.rr_state_item.set_label('Current: unavailable')
            return True

        if rate != self._last_rate:
            self._last_rate = rate
            self._update_rr_display(rate)

        return True

    def _update_rr_display(self, rate):
        self.rr_state_item.set_label(f'Current: {rate} Hz')
        if rate in self.rr_radio:
            self._rr_updating = True
            self.rr_radio[rate].set_active(True)
            self._rr_updating = False

    # ── key bindings ──────────────────────────────────────────────────────────

    def _rebuild_key_binding_submenus(self):
        for key_id, display_label, ksym, xmodmap_keycode, xmodmap_name in BINDABLE_KEYS:
            item = self.kb_menu_items.get(key_id)
            if not item:
                continue
            name, _ = _gs_get_binding(ksym)
            status = name if name else 'not bound'
            item.set_label(f'{display_label}  [{status}]')
            item.set_submenu(self._build_key_submenu(ksym, xmodmap_keycode, xmodmap_name))

    def _build_key_submenu(self, ksym, xmodmap_keycode, xmodmap_name):
        submenu = Gtk.Menu()

        name, _ = _gs_get_binding(ksym)
        header = Gtk.MenuItem(label=f'Bound: {name}' if name else 'Not bound')
        header.set_sensitive(False)
        submenu.append(header)
        submenu.append(Gtk.SeparatorMenuItem())

        for action_label, action_cmd in PRESET_ACTIONS:
            mi = Gtk.MenuItem(label=action_label)
            mi.connect('activate', self._on_bind_preset,
                       ksym, action_label, action_cmd, xmodmap_keycode, xmodmap_name)
            submenu.append(mi)

        submenu.append(Gtk.SeparatorMenuItem())

        enter_mi = Gtk.MenuItem(label='Enter command…')
        enter_mi.connect('activate', self._on_bind_custom, ksym, xmodmap_keycode, xmodmap_name)
        submenu.append(enter_mi)

        browse_mi = Gtk.MenuItem(label='Browse for executable…')
        browse_mi.connect('activate', self._on_bind_browse, ksym, xmodmap_keycode, xmodmap_name)
        submenu.append(browse_mi)

        submenu.append(Gtk.SeparatorMenuItem())

        clear_mi = Gtk.MenuItem(label='Clear binding')
        clear_mi.connect('activate', self._on_clear_binding, ksym)
        submenu.append(clear_mi)

        submenu.show_all()
        return submenu

    def _on_bind_preset(self, widget, ksym, name, cmd, xmodmap_keycode, xmodmap_name):
        if xmodmap_keycode:
            _ensure_xmodmap(xmodmap_keycode, xmodmap_name)
        _gs_set_binding(ksym, name, cmd)

    def _on_bind_custom(self, widget, ksym, xmodmap_keycode, xmodmap_name):
        dialog = Gtk.Dialog(title='Key Binding — Enter Command', flags=0)
        dialog.add_buttons(Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
                           Gtk.STOCK_OK,     Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_spacing(8)
        content.set_margin_start(12)
        content.set_margin_end(12)
        content.set_margin_top(12)
        content.set_margin_bottom(4)
        lbl = Gtk.Label(label='Command to run when key is pressed:')
        lbl.set_xalign(0)
        content.add(lbl)
        entry = Gtk.Entry()
        entry.set_width_chars(60)
        _, current_cmd = _gs_get_binding(ksym)
        if current_cmd:
            entry.set_text(current_cmd)
        entry.connect('activate', lambda _: dialog.response(Gtk.ResponseType.OK))
        content.add(entry)
        dialog.show_all()
        if dialog.run() == Gtk.ResponseType.OK:
            cmd = entry.get_text().strip()
            if cmd:
                if xmodmap_keycode:
                    _ensure_xmodmap(xmodmap_keycode, xmodmap_name)
                _gs_set_binding(ksym, cmd, cmd)
        dialog.destroy()

    def _on_bind_browse(self, widget, ksym, xmodmap_keycode, xmodmap_name):
        dialog = Gtk.FileChooserDialog(
            title='Key Binding — Choose Executable',
            parent=None,
            action=Gtk.FileChooserAction.OPEN,
            buttons=(Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
                     Gtk.STOCK_OPEN,   Gtk.ResponseType.OK),
        )
        dialog.set_current_folder(os.path.expanduser('~/.local/bin'))
        if dialog.run() == Gtk.ResponseType.OK:
            path = dialog.get_filename()
            if path:
                if xmodmap_keycode:
                    _ensure_xmodmap(xmodmap_keycode, xmodmap_name)
                _gs_set_binding(ksym, os.path.basename(path), path)
        dialog.destroy()

    def _on_clear_binding(self, widget, ksym):
        _gs_clear_binding(ksym)


# ── entry point ───────────────────────────────────────────────────────────────

def main():
    YogaTray()
    Gtk.main()


if __name__ == '__main__':
    main()

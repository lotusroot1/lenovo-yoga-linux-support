#!/usr/bin/env bash
# Toggle display refresh rate between 90Hz and 60Hz.
#
# 60Hz is only available at native resolution (2880x1800) on the Yoga 9i Gen 7.
# When the current mode is lower (e.g. 1920x1200), the mode must change.
# To avoid display scaling being recalculated by the desktop environment,
# the current xrandr transform is read before the switch and reapplied after,
# so only the refresh rate changes visibly.
set -euo pipefail

STATE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/yoga-tray/refresh-rate-state"
OUTPUT=$(xrandr | awk '/ connected/{print $1; exit}')

CURRENT_LINE=$(xrandr | grep -E '^\s+[0-9]+x[0-9]+.*\*' | head -1)
CURRENT_MODE=$(echo "$CURRENT_LINE" | awk '{print $1}')
CURRENT_RATE=$(echo "$CURRENT_LINE" | grep -oP '[\d.]+(?=\*)' | head -1 | cut -d. -f1)

# Read the active xrandr transform (3×3 matrix → 9 comma-separated values).
# This is the exact transform the compositor is using right now; reapplying it
# after a mode change keeps scaling identical.
CURRENT_TRANSFORM=$(xrandr --verbose 2>/dev/null | awk -v out="$OUTPUT" '
    $0 ~ ("^" out " ") { found=1 }
    found && /Transform:/ {
        r1=$2","$3","$4
        getline; r2=$1","$2","$3
        getline; r3=$1","$2","$3
        print r1","r2","r3
        exit
    }
')
CURRENT_TRANSFORM="${CURRENT_TRANSFORM:-1,0,0,0,1,0,0,0,1}"

if [ "${CURRENT_RATE:-0}" -ge 85 ]; then
    mkdir -p "$(dirname "$STATE_FILE")"
    printf '%s:%s:%s\n' "$CURRENT_MODE" "90" "$CURRENT_TRANSFORM" > "$STATE_FILE"

    xrandr --output "$OUTPUT" --mode 2880x1800 --rate 60 --transform "$CURRENT_TRANSFORM"
    notify-send --urgency=low --expire-time=2000 \
        --icon=video-display-symbolic "Refresh Rate" "60 Hz — Power Saver"
else
    PREV_MODE="" PREV_RATE="" PREV_TRANSFORM=""
    [ -f "$STATE_FILE" ] && IFS=: read -r PREV_MODE PREV_RATE PREV_TRANSFORM < "$STATE_FILE" || true
    PREV_MODE="${PREV_MODE:-2880x1800}"
    PREV_RATE="${PREV_RATE:-90}"
    PREV_TRANSFORM="${PREV_TRANSFORM:-1,0,0,0,1,0,0,0,1}"

    xrandr --output "$OUTPUT" --mode "$PREV_MODE" --rate "$PREV_RATE" --transform "$PREV_TRANSFORM"
    notify-send --urgency=low --expire-time=2000 \
        --icon=video-display-symbolic "Refresh Rate" "${PREV_RATE} Hz"
fi

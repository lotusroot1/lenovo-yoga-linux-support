# ── backend ───────────────────────────────────────────────────────────────────

def _find_cmd(name):
    for path in [f'/usr/local/bin/{name}', shutil.which(name)]:
        if path and os.path.isfile(path):
            return path
    return None

KBD_CMD          = _find_cmd('kbd-backlight')
PROFILE_CMD      = _find_cmd('platform-profile')
REFRESH_CMD      = _find_cmd('refresh-rate-toggle')
CONSERVATION_CMD = _find_cmd('battery-conservation')


def _sudo_run(cmd, *args):
    try:
        r = subprocess.run(['sudo', cmd] + list(args), capture_output=True, text=True, timeout=5)
        return r.stdout.strip(), r.returncode == 0
    except Exception as e:
        return str(e), False


def get_backlight():
    if not KBD_CMD:
        return 'error'
    out, ok = _sudo_run(KBD_CMD, 'get')
    return out if ok else 'error'


def set_backlight(state):
    if not KBD_CMD:
        return False
    _, ok = _sudo_run(KBD_CMD, 'set', state)
    return ok


def read_sysfs_brightness():
    try:
        with open(SYSFS_BRIGHTNESS) as f:
            return int(f.read().strip())
    except (OSError, ValueError):
        return -1


def read_profile():
    try:
        with open(SYSFS_PROFILE) as f:
            return f.read().strip()
    except Exception:
        return None


def set_profile(profile):
    if not PROFILE_CMD:
        return False
    _, ok = _sudo_run(PROFILE_CMD, 'set', profile)
    return ok


def read_conservation():
    try:
        with open(SYSFS_CONSERVATION) as f:
            return 'on' if f.read().strip() == '1' else 'off'
    except Exception:
        return None


def set_conservation(state):
    if not CONSERVATION_CMD:
        return False
    _, ok = _sudo_run(CONSERVATION_CMD, 'set', state)
    return ok


def get_refresh_rate():
    return _get_refresh_rate_wayland() if _IS_WAYLAND else _get_refresh_rate_x11()


def _get_refresh_rate_x11():
    global _xlib_conn
    if _HAS_XLIB:
        try:
            if _xlib_conn is None:
                _xlib_conn = _xlib_display.Display()
            d = _xlib_conn
            screen = d.screen()
            res = _xlib_randr.get_screen_resources_current(screen.root)
            for crtc_id in res.crtcs:
                crtc = _xlib_randr.get_crtc_info(screen.root, crtc_id, res.config_timestamp)
                if crtc.mode:
                    for mode in res.modes:
                        if mode.id == crtc.mode:
                            rate = round(mode.dot_clock / (mode.h_total * mode.v_total))
                            return 90 if rate >= 85 else 60
        except Exception:
            _xlib_conn = None  # reset on error so next call reopens
            pass
    # fallback: xrandr subprocess (slow — only reached if python3-xlib is absent)
    try:
        out = subprocess.check_output(['xrandr'], text=True, timeout=3)
        for line in out.splitlines():
            if '*' in line:
                m = re.search(r'(\d+\.\d+)\*', line)
                if m:
                    return 90 if float(m.group(1)) >= 85 else 60
    except Exception:
        pass
    return None


def _get_refresh_rate_wayland():
    try:
        import dbus
        bus = dbus.SessionBus()
        proxy = bus.get_object('org.gnome.Mutter.DisplayConfig',
                               '/org/gnome/Mutter/DisplayConfig')
        iface = dbus.Interface(proxy, 'org.gnome.Mutter.DisplayConfig')
        _, monitors, _, _ = iface.GetCurrentState()
        for (_connector, _vendor, _product, _serial), modes, _props in monitors:
            for _mid, _w, _h, rate, _pscale, _scales, mode_props in modes:
                if mode_props.get('is-current'):
                    return 90 if float(rate) >= 85 else 60
    except Exception:
        pass
    return None


def toggle_refresh_rate():
    if not REFRESH_CMD:
        return False
    try:
        subprocess.Popen([REFRESH_CMD, '--silent'])
        return True
    except Exception:
        return False


def _find_ideapad_device():
    try:
        with open('/proc/bus/input/devices') as f:
            content = f.read()
        for block in content.split('\n\n'):
            if 'Ideapad extra buttons' in block:
                for line in block.splitlines():
                    if line.startswith('H: Handlers='):
                        m = re.search(r'event(\d+)', line)
                        if m:
                            return f'/dev/input/event{m.group(1)}'
    except Exception:
        pass
    return None


# ── YogaTray ──────────────────────────────────────────────────────────────────

class YogaTray:
    def __init__(self):
        self._sections        = [
            BacklightSection(),
            ProfileSection(),
            ConservationSection(),
            RefreshRateSection(),
            KeyBindingsSection(),
        ]
        self._pending_notifs  = {}   # id(section) → section
        self._notify_timer    = None
        self._control_panel   = None

        max_poll = max(
            (s.poll_interval_ms for s in self._sections if s.poll_interval_ms),
            default=0,
        )
        headroom = TIMING['notification_delay_ms']
        assert headroom > 0, (
            f"notification_delay_ms must be > 0 (got {headroom}). "
            f"Fix in ~/.config/yoga-tray/timing.conf"
        )
        self._notify_debounce_ms = max_poll + headroom

        self._build_menu()
        self._setup_indicator()
        for section in self._sections:
            section.setup(self)
        for section in self._sections:
            section.refresh()

    # ── indicator ─────────────────────────────────────────────────────────────

    def _setup_indicator(self):
        if HAS_XAPP:
            self.status_icon = XApp.StatusIcon()
            self.status_icon.set_icon_name(DEFAULT_ICON)
            self.status_icon.set_tooltip_text('Yoga 9i — Backlight & Profile')
            self.status_icon.set_secondary_menu(self.menu)
            self.status_icon.connect('activate', lambda *_: self._open_control_panel())
        elif HAS_APPINDICATOR:
            self.indicator = AppIndicator3.Indicator.new(
                'yoga-tray', DEFAULT_ICON, AppIndicator3.IndicatorCategory.HARDWARE,
            )
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_menu(self.menu)
        else:
            self.status_icon = Gtk.StatusIcon.new_from_icon_name(DEFAULT_ICON)
            self.status_icon.set_tooltip_text('Yoga 9i — Backlight & Profile')
            self.status_icon.connect('activate', lambda *_: self._open_control_panel())
            self.status_icon.connect('popup-menu', self._on_statusicon_popup)

    def _on_statusicon_popup(self, icon, button, time):
        self.menu.popup(None, None, Gtk.StatusIcon.position_menu, icon, button, time)

    def set_tray_icon(self, icon_name, title=''):
        if HAS_XAPP:
            self.status_icon.set_icon_name(icon_name)
            if title:
                self.status_icon.set_tooltip_text(title)
        elif HAS_APPINDICATOR:
            self.indicator.set_icon_full(icon_name, title)
            if title:
                self.indicator.set_title(title)
        else:
            self.status_icon.set_from_icon_name(icon_name)

    @property
    def notifications_enabled(self):
        return HAS_NOTIFY and self._notif_item.get_active()

    def queue_notify(self, section):
        """Mark a section as having a pending notification. Timer starts once and is never reset —
        rapid changes just overwrite the section's slot; fire time reads current state."""
        self._pending_notifs[id(section)] = section
        if self._notify_timer is None:
            self._notify_timer = GLib.timeout_add(self._notify_debounce_ms, self._fire_combined_notify)

    def _fire_combined_notify(self):
        self._notify_timer = None
        sections = list(self._pending_notifs.values())
        self._pending_notifs.clear()
        valid = [
            info
            for sec in sections
            for info in [sec.notify_info(sec._last_state)]
            if info
        ]
        if not valid:
            return False
        if len(valid) == 1:
            title, body, icon = valid[0]
        else:
            title = 'Yoga Status'
            body  = '\n'.join(f'{t}: {b}' for t, b, _ in valid)
            icon  = DEFAULT_ICON
        n = Notify.Notification.new(title, body, icon)
        n.set_timeout(2000)
        try:
            n.show()
        except Exception:
            pass
        return False

    # ── control panel ─────────────────────────────────────────────────────────

    def _open_control_panel(self):
        if self._control_panel is None:
            self._control_panel = ControlPanel(self._sections)
            self._control_panel.connect('destroy',
                lambda _: setattr(self, '_control_panel', None))
        else:
            self._control_panel.deiconify()
            self._control_panel.present()

    # ── menu ──────────────────────────────────────────────────────────────────

    def _build_menu(self):
        self.menu = Gtk.Menu()
        self.menu.connect('show', lambda _: GLib.idle_add(self._on_menu_open))

        for section in self._sections:
            for widget in section.build_menu_items():
                self.menu.append(widget)
            self.menu.append(Gtk.SeparatorMenuItem())

        self._notif_item = Gtk.CheckMenuItem(label='Notifications')
        self._notif_item.set_active(load_pref('notifications', 'true') == 'true')
        self._notif_item.connect('toggled', lambda w: save_pref(
            'notifications', 'true' if w.get_active() else 'false'
        ))
        self.menu.append(self._notif_item)

        startup_item = Gtk.CheckMenuItem(label='Run on startup')
        startup_item.set_active(is_autostart_enabled())
        startup_item.connect('toggled', lambda w: set_autostart(w.get_active()))
        self.menu.append(startup_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        panel_item = Gtk.MenuItem(label='Yoga Options…')
        panel_item.connect('activate', lambda _: self._open_control_panel())
        self.menu.append(panel_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label='Quit')
        quit_item.connect('activate', lambda _: Gtk.main_quit())
        self.menu.append(quit_item)

        self.menu.show_all()

    def _on_menu_open(self):
        for section in self._sections:
            section.on_menu_open()


# ── entry point ───────────────────────────────────────────────────────────────

def main():
    pid_file = os.path.join(CONFIG_DIR, 'yoga-tray.pid')
    os.makedirs(CONFIG_DIR, exist_ok=True)

    try:
        with open(pid_file, 'x') as f:
            f.write(str(os.getpid()))
    except FileExistsError:
        try:
            with open(pid_file) as f:
                old_pid = int(f.read().strip())
            os.kill(old_pid, 0)
            sys.exit(0)
        except (ValueError, ProcessLookupError, PermissionError):
            # Stale PID file — overwrite and continue.
            with open(pid_file, 'w') as f:
                f.write(str(os.getpid()))

    try:
        YogaTray()
        Gtk.main()
    finally:
        try:
            os.remove(pid_file)
        except FileNotFoundError:
            pass


if __name__ == '__main__':
    main()

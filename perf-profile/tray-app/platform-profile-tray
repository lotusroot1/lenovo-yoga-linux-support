#!/usr/bin/env python3
"""
platform-profile-tray  v1.0
System tray icon for Lenovo Yoga 9i Gen 7 performance profile control.

Right-click the tray icon to see the current profile and switch modes.
The tray icon and a desktop notification update automatically when the
hardware performance key cycles the profile.

Requires: python3-gi
Optional: gir1.2-appindicator3-0.1 (better tray integration on Cinnamon)
          gir1.2-notify-0.7       (hardware key state-change notifications)
"""

import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib

import subprocess
import shutil
import sys
import os

# ── profiles ──────────────────────────────────────────────────────────────────

PROFILES = [
    ('low-power',   'Power Saver'),
    ('balanced',    'Balanced'),
    ('performance', 'Performance'),
]

PROFILE_LABELS = {k: v for k, v in PROFILES}

PROFILE_ICON_CANDIDATES = {
    'low-power':   ['power-profile-power-saver-symbolic',  'battery-low-symbolic'],
    'balanced':    ['power-profile-balanced-symbolic',     'battery-good-symbolic'],
    'performance': ['power-profile-performance-symbolic',  'battery-full-charged-symbolic'],
}

DEFAULT_ICON = 'preferences-system-symbolic'

SYSFS_PROFILE = '/sys/firmware/acpi/platform_profile'

# Poll interval for picking up hardware key presses (sysfs doesn't inotify).
POLL_MS = 2000

# Debounce notifications — hardware key cycles profiles rapidly.
NOTIFICATION_DEBOUNCE_MS = 1500

# ── paths ─────────────────────────────────────────────────────────────────────

TRAY_DESKTOP = os.path.expanduser('~/.config/autostart/platform-profile-tray.desktop')
CONFIG_DIR    = os.path.expanduser('~/.config/platform-profile-tray')

# ── optional libraries ────────────────────────────────────────────────────────

try:
    gi.require_version('AppIndicator3', '0.1')
    from gi.repository import AppIndicator3
    HAS_APPINDICATOR = True
except (ValueError, ImportError):
    HAS_APPINDICATOR = False

try:
    gi.require_version('Notify', '0.7')
    from gi.repository import Notify
    HAS_NOTIFY = Notify.init('platform-profile-tray')
except Exception:
    HAS_NOTIFY = False

# ── backend ───────────────────────────────────────────────────────────────────

def _find_backend():
    for path in ['/usr/local/bin/platform-profile', shutil.which('platform-profile')]:
        if path and os.path.isfile(path):
            return path
    return None

BACKEND = _find_backend()


def read_profile():
    try:
        with open(SYSFS_PROFILE) as f:
            return f.read().strip()
    except Exception:
        return None


def set_profile(profile):
    if not BACKEND:
        return False
    try:
        r = subprocess.run(
            ['sudo', BACKEND, 'set', profile],
            capture_output=True, timeout=5,
        )
        return r.returncode == 0
    except Exception:
        return False

# ── persistent preferences ────────────────────────────────────────────────────

def load_pref(name, default):
    try:
        with open(os.path.join(CONFIG_DIR, name)) as f:
            return f.read().strip()
    except FileNotFoundError:
        return default


def save_pref(name, value):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(os.path.join(CONFIG_DIR, name), 'w') as f:
        f.write(str(value))

# ── autostart ─────────────────────────────────────────────────────────────────

def is_autostart_enabled():
    return os.path.isfile(TRAY_DESKTOP)


def set_autostart(enabled):
    if enabled:
        os.makedirs(os.path.dirname(TRAY_DESKTOP), exist_ok=True)
        exe = shutil.which('platform-profile-tray') or sys.argv[0]
        with open(TRAY_DESKTOP, 'w') as f:
            f.write(
                '[Desktop Entry]\n'
                'Type=Application\n'
                'Name=Performance Profile Tray\n'
                'Comment=System tray control for Yoga 9i Gen 7 performance mode\n'
                f'Exec={exe}\n'
                f'Icon={DEFAULT_ICON}\n'
                'StartupNotify=false\n'
                'X-GNOME-Autostart-enabled=true\n'
            )
    else:
        try:
            os.remove(TRAY_DESKTOP)
        except FileNotFoundError:
            pass

# ── tray app ──────────────────────────────────────────────────────────────────

class PerfProfileTray:
    def __init__(self):
        self._updating       = False
        self._last_profile   = None
        self._notify_timer   = None
        self._profile_icons  = self._resolve_icons()

        self._build_menu()

        if HAS_APPINDICATOR:
            self.indicator = AppIndicator3.Indicator.new(
                'platform-profile-tray',
                DEFAULT_ICON,
                AppIndicator3.IndicatorCategory.HARDWARE,
            )
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_menu(self.menu)
        else:
            self.status_icon = Gtk.StatusIcon.new_from_icon_name(DEFAULT_ICON)
            self.status_icon.set_tooltip_text('Performance Profile')
            self.status_icon.connect('popup-menu', self._on_statusicon_popup)

        self.refresh()
        GLib.timeout_add(POLL_MS, self._poll)

    # ── icon resolution ───────────────────────────────────────────────────────

    def _resolve_icons(self):
        theme = Gtk.IconTheme.get_default()
        result = {}
        for key, candidates in PROFILE_ICON_CANDIDATES.items():
            for name in candidates:
                if theme.has_icon(name):
                    result[key] = name
                    break
            else:
                result[key] = DEFAULT_ICON
        return result

    def _set_tray_icon(self, profile):
        icon = self._profile_icons.get(profile, DEFAULT_ICON)
        if HAS_APPINDICATOR:
            self.indicator.set_icon_full(icon, profile or '')
        else:
            self.status_icon.set_from_icon_name(icon)

    # ── menu ──────────────────────────────────────────────────────────────────

    def _build_menu(self):
        self.menu = Gtk.Menu()
        self.menu.connect('show', lambda _: GLib.idle_add(self.refresh))

        header = Gtk.MenuItem(label='  Performance Profile')
        header.set_sensitive(False)
        self.menu.append(header)

        self.state_item = Gtk.MenuItem(label='Current: …')
        self.state_item.set_sensitive(False)
        self.menu.append(self.state_item)

        self.no_backend_item = Gtk.MenuItem(
            label='⚠  backend not found — run sudo install.sh'
        )
        self.no_backend_item.set_sensitive(False)
        self.menu.append(self.no_backend_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        self.radio = {}
        group = None
        for key, label in PROFILES:
            item = Gtk.RadioMenuItem.new_with_label(group, label)
            if group is None:
                group = item.get_group()
            item.connect('toggled', self._on_toggled, key)
            self.menu.append(item)
            self.radio[key] = item

        self.menu.append(Gtk.SeparatorMenuItem())

        self.notif_item = Gtk.CheckMenuItem(label='Notifications')
        self.notif_item.set_active(load_pref('notifications', 'true') == 'true')
        self.notif_item.connect('toggled', lambda w: save_pref(
            'notifications', 'true' if w.get_active() else 'false'
        ))
        self.menu.append(self.notif_item)

        self.startup_item = Gtk.CheckMenuItem(label='Run on startup')
        self.startup_item.set_active(is_autostart_enabled())
        self.startup_item.connect('toggled', lambda w: set_autostart(w.get_active()))
        self.menu.append(self.startup_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label='Quit')
        quit_item.connect('activate', lambda _: Gtk.main_quit())
        self.menu.append(quit_item)

        self.menu.show_all()

    # ── callbacks ─────────────────────────────────────────────────────────────

    def _on_statusicon_popup(self, icon, button, time):
        self.menu.popup(
            None, None,
            Gtk.StatusIcon.position_menu, icon,
            button, time,
        )

    def _on_toggled(self, widget, profile):
        if not self._updating and widget.get_active():
            if set_profile(profile):
                self._last_profile = profile
                self._update_display(profile)

    def _poll(self):
        self.refresh()
        return True

    # ── state refresh ─────────────────────────────────────────────────────────

    def refresh(self):
        profile = read_profile()
        installed = BACKEND is not None

        self.no_backend_item.set_visible(not installed)
        for item in self.radio.values():
            item.set_sensitive(installed)

        if profile != self._last_profile:
            if self._last_profile is not None:
                self._schedule_notification(profile)
            self._last_profile = profile
            self._update_display(profile)

        return True

    def _update_display(self, profile):
        label = PROFILE_LABELS.get(profile, profile or 'unknown')
        self.state_item.set_label(f'Current: {label}')
        self._set_tray_icon(profile)

        if profile in self.radio:
            self._updating = True
            self.radio[profile].set_active(True)
            self._updating = False

        if HAS_APPINDICATOR and profile:
            self.indicator.set_title(f'Profile: {label}')

    # ── notifications ─────────────────────────────────────────────────────────

    def _schedule_notification(self, profile):
        if not HAS_NOTIFY or not self.notif_item.get_active():
            return
        if self._notify_timer is not None:
            GLib.source_remove(self._notify_timer)
        self._notify_timer = GLib.timeout_add(
            NOTIFICATION_DEBOUNCE_MS, self._fire_notification, profile
        )

    def _fire_notification(self, profile):
        self._notify_timer = None
        if not self.notif_item.get_active() or profile != self._last_profile:
            return False
        label = PROFILE_LABELS.get(profile, profile)
        icon  = self._profile_icons.get(profile, DEFAULT_ICON)
        n = Notify.Notification.new('Performance Profile', label, icon)
        n.set_timeout(2000)
        try:
            n.show()
        except Exception:
            pass
        return False


# ── entry point ───────────────────────────────────────────────────────────────

def main():
    PerfProfileTray()
    Gtk.main()


if __name__ == '__main__':
    main()
